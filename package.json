{
  "name": "@camcima/finita",
  "version": "2.0.0",
  "description": "A full-featured finite state machine library for TypeScript",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=default --reporter=junit --outputFile=test-report.junit.xml",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc --project tsconfig.test.json && eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "release-it",
    "prepare": "lefthook install"
  },
  "keywords": [
    "statemachine",
    "state machine",
    "fsm",
    "status",
    "process"
  ],
  "author": "camcima (https://github.com/camcima)",
  "contributors": [
    "metabor (https://github.com/metabor)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camcima/finita.git"
  },
  "homepage": "https://github.com/camcima/finita",
  "bugs": {
    "url": "https://github.com/camcima/finita/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
